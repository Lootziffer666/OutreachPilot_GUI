# GEMINI_API_KEY: Required for Gemini AI API calls (fallback mode).
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# VITE_BACKEND_URL: URL of the Python OutreachPilot backend.
# When set, the GUI uses real Reddit scanning via the Python backend instead
# of the Gemini mock mode.  Leave unset to use http://localhost:8000 (default).
# VITE_BACKEND_URL=http://localhost:8000
